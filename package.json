{
  "name": "brilliant-learning-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*", "services/*"],
  "scripts": {
    "dev:web": "npm --workspace @blp/web run dev",
    "build": "npm --workspaces --if-present run build",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint",
    "start:web": "npm --workspace @blp/web run start",
    "db:generate": "npm --workspace @blp/db run generate",
    "pipeline:demo": "npm --workspace @blp/pipeline run demo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "tsx": "^4.19.2"
  }
}
